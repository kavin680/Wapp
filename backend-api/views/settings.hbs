<div class="app-layout">
  {{> sidebar page="settings"}}
  <div class="main-content">
    {{> topbar pageTitle="Settings" user=user}}
    <div class="content-area">

      {{#if flash}}
      <div class="alert alert-success">{{flash}}</div>
      {{/if}}
      {{#if error}}
      <div class="alert alert-danger">{{error}}</div>
      {{/if}}

      <div class="card">
        <div class="card-header">
          <h3>System Settings</h3>
          <button class="btn btn-primary btn-sm" onclick="openModal('createSettingModal')">+ Add Setting</button>
        </div>
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Key</th>
                <th>Value</th>
                <th>Category</th>
                <th>Updated</th>
              </tr>
            </thead>
            <tbody>
              {{#each settings}}
              <tr>
                <td><strong>{{this.key}}</strong></td>
                <td><code>{{this.value}}</code></td>
                <td><span class="badge badge-default">{{this.category}}</span></td>
                <td class="text-muted">{{this.updatedAt}}</td>
              </tr>
              {{else}}
              <tr><td colspan="4" class="empty-state">No settings configured</td></tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h3>User Preferences</h3>
        </div>
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Key</th>
                <th>Value</th>
                <th>Updated</th>
              </tr>
            </thead>
            <tbody>
              {{#each preferences}}
              <tr>
                <td><strong>{{this.key}}</strong></td>
                <td><code>{{this.value}}</code></td>
                <td class="text-muted">{{this.updatedAt}}</td>
              </tr>
              {{else}}
              <tr><td colspan="3" class="empty-state">No preferences set</td></tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Create Setting Modal -->
<div class="modal-backdrop" id="createSettingModal">
  <div class="modal">
    <div class="modal-header">
      <h3>Add System Setting</h3>
      <button class="modal-close" onclick="closeModal('createSettingModal')">&times;</button>
    </div>
    <form method="POST" action="/admin/settings">
      <div class="modal-body">
        <div class="form-group">
          <label for="settingKey">Key</label>
          <input type="text" id="settingKey" name="key" class="form-control" placeholder="e.g. max_retry_attempts" required>
        </div>
        <div class="form-group">
          <label for="settingValue">Value</label>
          <input type="text" id="settingValue" name="value" class="form-control" placeholder="Setting value" required>
        </div>
        <div class="form-group">
          <label for="settingCategory">Category</label>
          <input type="text" id="settingCategory" name="category" class="form-control" placeholder="e.g. messaging" value="general">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('createSettingModal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Setting</button>
      </div>
    </form>
  </div>
</div>
