# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="Wapp"
NODE_ENV=development
APP_PORT=3000
API_PREFIX=api
API_VERSION=v1
FRONTEND_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (docker-compose.yml starts a local DB)
DATABASE_URL="postgresql://postgres:password@localhost:5432/wapp_db?schema=public"
DATABASE_LOGGING=false

# ─── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-me
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
EMAIL_VERIFICATION_ENABLED=false
PASSWORD_RESET_TOKEN_EXPIRES_IN=3600

# ─── Redis (optional – app runs without it) ─────────────────────────────────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=300
REDIS_KEY_PREFIX=wapp:

# ─── Mail (optional) ─────────────────────────────────────────────────────────
MAIL_ENABLED=false
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="Wapp <noreply@wapp.com>"

# ─── Queue (optional – enables async message processing via BullMQ) ─────────
QUEUE_ENABLED=false
QUEUE_REMOVE_ON_COMPLETE=100
QUEUE_REMOVE_ON_FAIL=50
QUEUE_DEFAULT_ATTEMPTS=3

# ─── Monitoring (optional) ──────────────────────────────────────────────────
MONITORING_ENABLED=false
MONITORING_PROVIDER=none
DATADOG_API_KEY=
SENTRY_DSN=
METRICS_PORT=9090

# ─── Encryption ────────────────────────────────────────────────────────────────
# 32-character key used to encrypt provider credentials at rest
ENCRYPTION_KEY=your-32-char-encryption-key-here!

# ─── WhatsApp Cloud API ─────────────────────────────────────────────────────
# Get these from https://developers.facebook.com → your WhatsApp app
WHATSAPP_API_URL=https://graph.facebook.com/v21.0
WHATSAPP_API_TOKEN=              # Permanent / temporary access token
WHATSAPP_PHONE_NUMBER_ID=        # Phone Number ID from the API Setup page
WHATSAPP_BUSINESS_ACCOUNT_ID=    # WhatsApp Business Account ID
WHATSAPP_WEBHOOK_VERIFY_TOKEN=   # Any string you choose for webhook verification
WHATSAPP_APP_SECRET=             # App Secret (used to verify webhook signatures)

# ─── Message Processing ───────────────────────────────────────────────────────
MESSAGE_RETRY_MAX_ATTEMPTS=3
MESSAGE_RETRY_BACKOFF_MS=1000
CAMPAIGN_BATCH_SIZE=50
CAMPAIGN_RATE_LIMIT=80           # Messages per minute for campaigns
CAMPAIGN_SCHEDULER_INTERVAL_MS=60000

# ─── Billing (optional) ──────────────────────────────────────────────────────
BILLING_ENABLED=false
BILLING_DEFAULT_CURRENCY=USD

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
